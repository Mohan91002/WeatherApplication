<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.0" />
    <!-- Pin the transitive Microsoft.OpenApi to a patched version (>= 2.7.5) to resolve
         NU1903 / GHSA-v5pm-xwqc-g5wc (circular schema references can terminate OpenAPI
         parsing). Stays on the 2.x line for API compatibility with AspNetCore.OpenApi 10. -->
    <PackageReference Include="Microsoft.OpenApi" Version="2.7.6" />
  </ItemGroup>

  <!-- The test project lives under Tests/; keep its .cs files out of the web build. -->
  <ItemGroup>
    <Compile Remove="Tests/**/*.cs" />
    <Content Remove="Tests/**" />
    <None Remove="Tests/**" />
  </ItemGroup>

</Project>
